generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum QuestType {
  MAIN
  SIDE
  DAILY
  ACHIEVEMENT
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  characters    Character[]
  saves         GameSave[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Character {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  gender        String
  birthDate     DateTime
  birthTime     String
  height        Int
  weight        Int
  zodiac        String
  element       String
  temperament   String
  talent        String
  jobName       String
  jobRarity     Rarity
  level         Int         @default(1)
  reincarnation Int         @default(0)
  exp           Int         @default(0)
  gold          Int         @default(0)
  stats         Json
  traits        Json
  equipment     Equipment[]
  inventory     InventoryItem[]
  quests        Quest[]
  achievements  Achievement[]
  dungeonRuns   DungeonRun[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Equipment {
  id          String     @id @default(cuid())
  characterId String?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: Cascade)
  name        String
  slot        String
  rarity      Rarity
  level       Int
  enhance     Int        @default(0)
  attack      Int?
  defense     Int?
  stats       Json
  options     Json
  setName     String?
  price       Int
  createdAt   DateTime   @default(now())
}

model InventoryItem {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemType    String
  itemKey     String
  quantity    Int       @default(1)
  payload     Json
  updatedAt   DateTime  @updatedAt
}

model Quest {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  type        QuestType
  title       String
  goal        String
  progress    Int       @default(0)
  target      Int
  reward      String
  completed   Boolean   @default(false)
}

model Achievement {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  title       String
  text        String
  reward      String
  unlocked    Boolean   @default(false)
  unlockedAt  DateTime?
}

model DungeonRun {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  dungeonKey  String
  floor       Int       @default(1)
  roomIndex   Int       @default(0)
  rooms       Json
  status      String    @default("IN_PROGRESS")
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
}

model GameSave {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payload   Json
  checksum  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
